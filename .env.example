# 환경변수 템플릿. 이 파일을 .env로 복사한 뒤 값을 채운다.
#   cp .env.example .env
# .env는 git에 커밋되지 않는다. 실제 비밀값은 절대 이 example 파일에 적지 말 것.

# ===== docker-compose (로컬 인프라) =====
# compose가 자동으로 읽어 MySQL 컨테이너에 주입한다.
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=couponrush
MYSQL_USER=coupon
MYSQL_PASSWORD=

# ===== Spring 앱 (서버 배포 시 주입) =====
# 로컬 IDE 실행은 application.yml 기본값으로 동작하므로 아래는 선택.
# 서버(OCI)에서는 실제 운영값을 환경변수로 주입한다.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=couponrush
DB_USERNAME=coupon
DB_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BOOTSTRAP=localhost:9092

# 운영 전용 비밀값. 기본값 없이 서버에서만 주입한다. (HS256, 최소 256비트=32바이트 이상)
JWT_SECRET=
# Access 토큰 만료(ms). 기본 1시간. 비워두면 application.yml 기본값 사용.
JWT_EXPIRATION=3600000
